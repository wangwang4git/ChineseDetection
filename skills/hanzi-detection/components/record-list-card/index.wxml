<!-- components/record-list-card/index.wxml -->
<!-- ratio=1:1，展示历史记录列表 -->

<view class="card-container">
  <view class="card-header">
    <view class="card-title">历史检测记录</view>
    <view class="stat-link" hover-class="stat-link-hover" bindtap="onTapStatistics">查看统计</view>
  </view>

  <view wx:if="{{visibleRecords.length === 0}}" class="empty-state">
    <view class="empty-text">暂无检测记录</view>
    <view class="empty-hint">快去测一测吧！</view>
  </view>

  <view wx:else class="record-list">
    <view wx:for="{{visibleRecords}}" wx:key="id"
          class="record-item" hover-class="record-item-hover"
          bindtap="onTapRecord"
          data-id="{{item.id}}">
      <view class="record-left">
        <view class="record-score">{{item.estimatedVocabulary}}<text class="record-unit">字</text></view>
        <view class="record-time">{{item.testTime}}</view>
      </view>
      <view class="record-right">
        <view class="record-stat">
          <view class="stat-num">{{item.totalTestedCount}}</view>
          <view class="stat-label">测试题数</view>
        </view>
        <view class="record-arrow">&gt;</view>
      </view>
    </view>
  </view>

  <view wx:if="{{omittedCount > 0}}" class="card-footer">
    <view class="btn-view-all" hover-class="btn-view-all-hover" bindtap="onTapViewAll">
      查看全部（共{{totalCount}}条）
    </view>
  </view>
</view>
